NODE_ENV=production
PORT=10000

# Postgres connection string (Supabase/Neon/Render PG), with SSL enabled.
DATABASE_URL=postgresql://postgres:password@host:6543/postgres?sslmode=require

# Service-to-service bearer token used by Supabase Edge Functions.
SERVICE_API_KEY=replace-with-long-random-secret

# OpenAI key for query embedding generation.
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional behavior tuning
DEFAULT_TOP_K=20
MAX_TOP_K=50
DEFAULT_MIN_SCORE=0.2
